ANTHROPIC_API_KEY=your-key-here
ANTHROPIC_MODEL=claude-sonnet-5
PORT=3000
# DATA_DIR=./data
# Unset by default: the app falls back to a repo-root `data/` directory. If you
# set this, it's resolved relative to the current working directory the
# process is started from (e.g. `./data` run from `server/` lands in
# `server/data`, not the repo root) — use an absolute path to avoid surprises.
